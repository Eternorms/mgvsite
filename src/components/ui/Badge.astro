---
interface Props {
  variant?: 'gold' | 'navy' | 'white' | 'success';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  variant = 'gold',
  size = 'md',
  class: className = '',
} = Astro.props;

const baseStyles = 'inline-flex items-center font-accent font-semibold uppercase tracking-wider rounded-full';

const variants = {
  gold: 'bg-gold/10 text-gold',
  navy: 'bg-navy text-white',
  white: 'bg-white/20 text-white backdrop-blur-sm',
  success: 'bg-green-100 text-green-700',
};

const sizes = {
  sm: 'px-2 py-0.5 text-[10px]',
  md: 'px-3 py-1 text-xs',
};

const classes = [
  baseStyles,
  variants[variant],
  sizes[size],
  className,
].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>
