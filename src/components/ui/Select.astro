---
interface Option {
  value: string;
  label: string;
}

interface Props {
  name: string;
  label?: string;
  options: Option[];
  placeholder?: string;
  required?: boolean;
  class?: string;
  value?: string;
}

const {
  name,
  label,
  options,
  placeholder = 'Selecione...',
  required = false,
  class: className = '',
  value = '',
} = Astro.props;

const selectId = `select-${name}`;
---

<div class={`flex flex-col gap-2 ${className}`}>
  {label && (
    <label for={selectId} class="text-sm font-medium text-navy">
      {label}
      {required && <span class="text-gold ml-1">*</span>}
    </label>
  )}
  <div class="relative">
    <select
      id={selectId}
      name={name}
      required={required}
      class="w-full px-4 py-3 border border-gray-border rounded-lg bg-white text-navy appearance-none cursor-pointer transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-gold/20 focus:border-gold"
    >
      <option value="" disabled selected={!value}>{placeholder}</option>
      {options.map((option) => (
        <option value={option.value} selected={value === option.value}>
          {option.label}
        </option>
      ))}
    </select>
    <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
      <svg class="w-4 h-4 text-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</div>
