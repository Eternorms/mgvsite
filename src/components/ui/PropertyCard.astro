---
import type { Property } from '../../data/properties';
import { siteConfig } from '../../data/siteConfig';

interface Props {
  property: Property;
  class?: string;
  imageLoading?: 'eager' | 'lazy';
}

const { property, class: className = '', imageLoading = 'lazy', ...rest } = Astro.props;
const { slug, title, location, city, price, type, badge, badgeType, beds, baths, area, image } = property;

const badgeClasses: Record<string, string> = {
  gold: 'bg-gold text-navy',
  navy: 'bg-navy text-white border border-gold/50',
  excl: 'bg-gold/10 text-gold border border-gold/50 backdrop-blur-sm',
};

const whatsappHref = `${siteConfig.contact.whatsappHref}?text=${encodeURIComponent(`Tenho interesse no imóvel: ${title}`)}`;
---

<article {...rest} class={`group bg-white rounded-2xl overflow-hidden border border-navy/10 shadow-[0_4px_20px_rgba(11,29,51,0.08)] cursor-pointer transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg ${className}`}>

  <!-- Image area -->
  <div class="relative h-[220px] overflow-hidden">
    <img src={image} alt={title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.06]" loading={imageLoading} decoding="async" />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/10 via-transparent to-navy/50"></div>

    <!-- Badge -->
    {badge && (
      <div class={`absolute top-[14px] left-[14px] z-10 text-[9px] font-bold tracking-[0.12em] uppercase px-[11px] py-[5px] rounded-[5px] ${badgeClasses[badgeType]}`}>
        {badge}
      </div>
    )}

    <!-- Fav button -->
    <button
      class="pcard-fav absolute top-[14px] right-[14px] z-10 w-[34px] h-[34px] rounded-full bg-white/90 backdrop-blur-sm border-none flex items-center justify-center transition-transform duration-200 hover:scale-110 hover:bg-white"
      aria-label="Favoritar"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0B1D33" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
    </button>

    <!-- Price overlay -->
    <div class="absolute bottom-[14px] left-[14px] z-10 bg-navy backdrop-blur-md rounded-[7px] px-[13px] py-[6px] text-[15px] font-extrabold text-gold tracking-tight">
      {price}
    </div>
  </div>

  <!-- Body -->
  <div class="px-[18px] pt-[18px]">
    <h3 class="text-[14px] font-bold text-navy leading-snug mb-[6px]">{title}</h3>
    <div class="flex items-center gap-[5px] text-[11px] text-navy/50 mb-[14px]">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2C8.68 2 6 4.68 6 8c0 4.5 6 14 6 14s6-9.5 6-14c0-3.32-2.68-6-6-6z"/>
        <circle cx="12" cy="8" r="2"/>
      </svg>
      {location}, {city}
    </div>
  </div>

  <!-- Specs -->
  <div class="flex border-t border-navy/5 mx-[18px] pt-[12px]">
    {beds > 0 && (
    <div class="flex flex-1 items-center gap-[6px] text-[10.5px] font-semibold text-navy/50 relative">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 4v16M2 8h18a2 2 0 012 2v10M2 16h20"/><path d="M6 8V4"/>
        </svg>
        {beds} quartos
      </div>
    )}
    {baths > 0 && (
      <div class="flex flex-1 items-center gap-[6px] text-[10.5px] font-semibold text-navy/50 relative before:absolute before:left-0 before:top-[10%] before:h-[80%] before:w-px before:bg-navy/10 pl-[14px]">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 6 A3 3 0 0 1 15 6 L15 11 L3 11 L3 13 A9 9 0 0 0 21 13 L21 11 L15 11"/>
        </svg>
        {baths} ban.
      </div>
    )}
    <div class={`flex flex-1 items-center gap-[6px] text-[10.5px] font-semibold text-navy/50 relative before:absolute before:left-0 before:top-[10%] before:h-[80%] before:w-px before:bg-navy/10 ${beds > 0 || baths > 0 ? 'pl-[14px]' : ''}`}>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
      </svg>
      {area}m²
    </div>
  </div>

  <div class="px-[18px] pt-[10px]">
    <span class="inline-flex rounded-[6px] bg-navy/5 px-2.5 py-1 text-[9.5px] font-bold uppercase tracking-[0.12em] text-navy/50">{type}</span>
  </div>

  <!-- Footer buttons -->
  <div class="flex gap-[10px] p-[14px] pt-[12px]">
    <a
      href={`/imoveis/${slug}`}
      class="flex flex-1 items-center justify-center gap-[6px] text-[11px] font-bold tracking-[0.07em] px-[16px] py-[10px] rounded-[8px] bg-gold text-navy border-none transition-all duration-200 hover:bg-gold-dark hover:shadow-[0_6px_24px_rgba(201,168,76,0.32)]"
    >
      Ver detalhes
    </a>
    <a
      href={whatsappHref}
      target="_blank"
      rel="noopener"
      class="flex flex-1 items-center justify-center gap-[6px] text-[11px] font-bold tracking-[0.07em] px-[16px] py-[10px] rounded-[8px] bg-transparent text-navy border border-navy/10 transition-all duration-200 hover:border-navy"
    >
      WhatsApp
    </a>
  </div>
</article>
