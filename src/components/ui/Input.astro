---
interface Props {
  type?: 'text' | 'email' | 'tel' | 'number' | 'password';
  name: string;
  label?: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
  value?: string;
}

const {
  type = 'text',
  name,
  label,
  placeholder,
  required = false,
  class: className = '',
  value = '',
} = Astro.props;

const inputId = `input-${name}`;
---

<div class={`flex flex-col gap-2 ${className}`}>
  {label && (
    <label for={inputId} class="text-sm font-medium text-navy">
      {label}
      {required && <span class="text-gold ml-1">*</span>}
    </label>
  )}
  <input
    type={type}
    id={inputId}
    name={name}
    placeholder={placeholder}
    required={required}
    value={value}
    class="w-full px-4 py-3 border border-gray-border rounded-lg bg-white text-navy placeholder-gray transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-gold/20 focus:border-gold"
  />
</div>
