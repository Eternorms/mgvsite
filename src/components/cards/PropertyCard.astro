---
import Badge from '../ui/Badge.astro';

interface Props {
  title: string;
  location: string;
  price: string;
  image: string;
  href: string;
  beds?: number;
  baths?: number;
  area?: number;
  isNew?: boolean;
  isExclusive?: boolean;
  has3DTour?: boolean;
}

const {
  title,
  location,
  price,
  image,
  href,
  beds,
  baths,
  area,
  isNew = false,
  isExclusive = false,
  has3DTour = false,
} = Astro.props;
---

<a href={href} class="card group block">
  <!-- Image Container -->
  <div class="relative aspect-property overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />

    <!-- Badges -->
    <div class="absolute top-4 left-4 flex flex-wrap gap-2">
      {isNew && <Badge variant="gold">Novo</Badge>}
      {isExclusive && <Badge variant="navy">Exclusivo</Badge>}
      {has3DTour && <Badge variant="white">Tour 3D</Badge>}
    </div>

    <!-- Gradient overlay on hover -->
    <div class="absolute inset-0 bg-gradient-card opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>

  <!-- Content -->
  <div class="p-5">
    <!-- Location -->
    <div class="flex items-center gap-1.5 text-gray text-sm mb-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {location}
    </div>

    <!-- Title -->
    <h3 class="font-heading text-lg text-navy mb-3 group-hover:text-gold transition-colors line-clamp-2">
      {title}
    </h3>

    <!-- Features -->
    {(beds || baths || area) && (
      <div class="flex items-center gap-4 text-gray text-sm mb-4 border-t border-gray-border pt-4">
        {beds && (
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            {beds} quartos
          </div>
        )}
        {baths && (
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h8M8 11h8m-8 4h4" />
            </svg>
            {baths} banheiros
          </div>
        )}
        {area && (
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
            </svg>
            {area}m²
          </div>
        )}
      </div>
    )}

    <!-- Price -->
    <p class="font-heading text-xl text-navy font-medium">
      {price}
    </p>
  </div>
</a>
