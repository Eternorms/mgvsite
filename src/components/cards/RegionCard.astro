---
interface Props {
  name: string;
  propertyCount: number;
  image: string;
  href: string;
}

const { name, propertyCount, image, href } = Astro.props;
---

<a href={href} class="group relative block overflow-hidden rounded-2xl aspect-[4/5]">
  <!-- Background Image -->
  <img
    src={image}
    alt={name}
    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
  />

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/20 to-transparent"></div>

  <!-- Content -->
  <div class="absolute inset-0 flex flex-col justify-end p-6">
    <div class="decor-line mb-4 transition-all duration-300 group-hover:w-24"></div>
    <h3 class="font-heading text-2xl text-white mb-1">{name}</h3>
    <p class="text-white/70 text-sm font-accent">
      {propertyCount} imóveis disponíveis
    </p>
  </div>
</a>
