---
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Atendimento consultivo',
    desc: 'Cada cliente recebe um consultor dedicado com profundo conhecimento do litoral paulista e do mercado local.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Resposta em até 2 horas',
    desc: 'Garantimos retorno ágil em horário comercial. Seu tempo é tão valioso quanto o imóvel que você procura.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'CRECI regularizado',
    desc: 'Transações com toda segurança jurídica e transparência. Documentação completa do início ao fim.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Portfólio exclusivo',
    desc: 'Imóveis selecionados em Guarujá, Riviera de São Lourenço e Santos, com foco em médio e alto padrão.',
  },
];
---

<section id="features" class="bg-white border-t border-navy/5 border-b border-navy/5">
  <div class="flex items-start justify-center flex-wrap py-14 px-12 gap-0 max-w-[1200px] mx-auto">
    {features.map((feat, i) => (
      <div class={`flex flex-col items-center text-center px-8 gap-[14px] flex-1 min-w-[200px] max-w-[280px] relative ${i > 0 ? 'before:content-[""] before:absolute before:left-0 before:top-[10%] before:h-[80%] before:w-px before:bg-navy/10' : ''}`}>
        <div class="w-12 h-12 rounded-[12px] flex items-center justify-center border border-gold/20" style="background: linear-gradient(135deg, rgba(201,168,76,.1), rgba(201,168,76,.04));" set:html={feat.icon}></div>
        <div class="text-[13px] font-bold text-navy">{feat.title}</div>
        <div class="text-[11.5px] text-navy/50 leading-[1.7]">{feat.desc}</div>
      </div>
    ))}
  </div>
</section>

<style>
  @media (max-width: 900px) {
    section > div {
      flex-direction: column;
      align-items: center;
      padding: 40px 24px;
    }
    section > div > div {
      border-top: 1px solid rgba(11,29,51,.07);
      padding: 28px 0;
      max-width: 100%;
    }
    section > div > div:first-child {
      border-top: none;
      padding-top: 0;
    }
    section > div > div::before {
      display: none !important;
    }
  }
</style>
