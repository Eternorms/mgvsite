---
import { siteConfig } from '../../data/siteConfig';

const { heroSlides, stats } = siteConfig;
---

<section class="hero relative flex flex-col items-center justify-center overflow-hidden text-center" style="height: 100vh; min-height: 640px;">

  <!-- Carousel slides -->
  <div class="slides absolute inset-0 z-0" id="slides">
    {heroSlides.map((slide, i) => (
      <div
        class={`slide absolute inset-0 transition-opacity duration-[1400ms] ease-in-out bg-cover bg-center ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-index={i}
      >
        <!-- Gradient background -->
        <div class="absolute inset-0" style={`background: linear-gradient(145deg, ${slide.gradient.replace('from-[','').replace(']','').replace(' via-[','').replace(' to-[',',')});`}></div>
        <!-- Dark scrim overlay -->
        <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(8,22,40,.60) 0%, rgba(8,22,40,.42) 35%, rgba(8,22,40,.65) 70%, rgba(8,22,40,.92) 100%);"></div>
      </div>
    ))}
  </div>

  <!-- Grid texture overlay -->
  <div class="absolute inset-0 z-[1] pointer-events-none" style="background-image: linear-gradient(rgba(201,168,76,.025) 1px, transparent 1px), linear-gradient(90deg, rgba(201,168,76,.025) 1px, transparent 1px); background-size: 72px 72px;"></div>

  <!-- Gold glow -->
  <div class="absolute z-[1] pointer-events-none" style="top: -10%; left: 50%; transform: translateX(-50%); width: 900px; height: 600px; background: radial-gradient(ellipse, rgba(201,168,76,.055) 0%, transparent 70%);"></div>

  <!-- Hero body -->
  <div class="hero-body relative z-[3] flex flex-col items-center gap-[22px] px-6 w-full" style="max-width: 780px; animation: fadeUp 1s cubic-bezier(0.16,1,0.3,1) both;">

    <!-- Eyebrow -->
    <div class="flex items-center gap-3 text-[10px] font-bold tracking-[0.28em] text-gold uppercase before:content-[''] before:w-8 before:h-px before:bg-gold before:opacity-50 after:content-[''] after:w-8 after:h-px after:bg-gold after:opacity-50"
      style="animation: fadeUp 1s .1s cubic-bezier(0.16,1,0.3,1) both;">
      Guarujá &amp; Litoral Paulista
    </div>

    <!-- Title (Playfair Display) -->
    <h1 class="hero-title text-white leading-[1.08] tracking-tight" style="font-family: 'Playfair Display', serif; font-size: clamp(38px, 6vw, 64px); font-weight: 700; animation: fadeUp 1s .2s cubic-bezier(0.16,1,0.3,1) both;">
      Encontre o imóvel que<br/><em style="font-style: italic; color: #C9A84C; font-weight: 600;">permanece</em> com você
    </h1>

    <!-- Subtitle -->
    <p class="text-white/55 leading-[1.8] tracking-[0.01em]" style="font-size: 15px; max-width: 520px; animation: fadeUp 1s .3s cubic-bezier(0.16,1,0.3,1) both;">
      Apartamentos, casas e coberturas no litoral paulista.<br/>Atendimento consultivo, exclusivo e personalizado.
    </p>

    <!-- Search bar -->
    <div class="w-full" style="max-width: 720px; animation: fadeUp 1s .45s cubic-bezier(0.16,1,0.3,1) both;">
      <form
        class="flex items-stretch gap-1 rounded-[14px] p-2 bg-white"
        style="box-shadow: 0 20px 60px rgba(0,0,0,.28), 0 0 0 1px rgba(201,168,76,.12);"
        action="/imoveis"
        method="get"
      >
        <!-- Tipo -->
        <div class="sf flex-1 flex flex-col justify-center px-4 py-[10px] cursor-pointer rounded-[9px] relative transition-colors duration-200 hover:bg-gray-100 group/sf">
          <div class="text-[9px] font-bold tracking-[0.14em] uppercase text-navy/38 mb-1">Tipo de imóvel</div>
          <div class="flex items-center gap-1.5 text-[12.5px] font-semibold text-navy">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            <span id="sf-tipo-val">Apartamento</span>
          </div>
          <select name="tipo" class="absolute inset-0 opacity-0 cursor-pointer w-full" onchange="document.getElementById('sf-tipo-val').textContent = this.value">
            <option>Apartamento</option>
            <option>Casa</option>
            <option>Cobertura</option>
            <option>Terreno</option>
          </select>
        </div>

        <!-- Separador -->
        <div class="w-px bg-navy/10 self-[20%] my-auto" style="height: 60%;"></div>

        <!-- Localização -->
        <div class="sf flex-[1.3] flex flex-col justify-center px-4 py-[10px] cursor-pointer rounded-[9px] relative transition-colors duration-200 hover:bg-gray-100">
          <div class="text-[9px] font-bold tracking-[0.14em] uppercase text-navy/38 mb-1">Localização</div>
          <div class="flex items-center gap-1.5 text-[12.5px] text-navy/35">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.68 2 6 4.68 6 8c0 4.5 6 14 6 14s6-9.5 6-14c0-3.32-2.68-6-6-6z"/><circle cx="12" cy="8" r="2"/></svg>
            <span id="sf-local-val">Onde você quer morar?</span>
          </div>
          <select name="local" class="absolute inset-0 opacity-0 cursor-pointer w-full" onchange="const v=this.value; document.getElementById('sf-local-val').textContent = v||'Onde você quer morar?'; document.getElementById('sf-local-val').className = v ? 'text-navy' : 'text-navy/35'">
            <option value="">Onde você quer morar?</option>
            <option>Guarujá, SP</option>
            <option>Enseada</option>
            <option>Riviera de São Lourenço</option>
            <option>Santos, SP</option>
          </select>
        </div>

        <!-- Separador -->
        <div class="w-px bg-navy/10 self-[20%] my-auto" style="height: 60%;"></div>

        <!-- Preço -->
        <div class="sf flex-1 flex flex-col justify-center px-4 py-[10px] cursor-pointer rounded-[9px] relative transition-colors duration-200 hover:bg-gray-100">
          <div class="text-[9px] font-bold tracking-[0.14em] uppercase text-navy/38 mb-1">Faixa de preço</div>
          <div class="flex items-center gap-1.5 text-[12.5px] font-semibold text-navy">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            <span id="sf-preco-val">Qualquer valor</span>
          </div>
          <select name="preco" class="absolute inset-0 opacity-0 cursor-pointer w-full" onchange="document.getElementById('sf-preco-val').textContent = this.value">
            <option>Qualquer valor</option>
            <option>Até R$ 500k</option>
            <option>R$ 500k – R$ 1M</option>
            <option>R$ 1M – R$ 2M</option>
            <option>R$ 2M – R$ 5M</option>
            <option>Acima de R$ 5M</option>
          </select>
        </div>

        <!-- Botão buscar -->
        <button
          type="submit"
          class="flex items-center gap-2 px-7 py-[14px] bg-gold text-navy font-bold text-[11.5px] tracking-[0.08em] rounded-[9px] border-none cursor-pointer whitespace-nowrap flex-shrink-0 transition-all duration-200 hover:bg-gold-dark"
          style="color: #0B1D33;"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Buscar imóveis
        </button>
      </form>

      <!-- Quick chips -->
      <div class="hidden md:flex items-center justify-center gap-5 mt-4" style="animation: fadeUp 1s .55s cubic-bezier(0.16,1,0.3,1) both;">
        {['Frente mar', 'Lançamentos', 'Alto padrão', 'Para temporada', 'Área de lazer'].map((chip) => (
          <a href={`/imoveis?q=${encodeURIComponent(chip)}`} class="flex items-center gap-1.5 text-[11px] font-medium text-white/38 tracking-[0.04em] cursor-pointer transition-colors duration-200 hover:text-white/70 no-underline">
            <span class="w-1 h-1 rounded-full bg-gold opacity-60"></span>
            {chip}
          </a>
        ))}
      </div>
    </div>

    <!-- Stats -->
    <div class="flex items-center gap-12 pt-6 mt-1 border-t border-white/7 flex-wrap justify-center" style="animation: fadeUp 1s .65s cubic-bezier(0.16,1,0.3,1) both;">
      {stats.map((stat, i) => (
        <>
          {i > 0 && <div class="w-px h-9 bg-white/8 hidden sm:block"></div>}
          <div class="text-center">
            <div class="text-[26px] font-extrabold text-white leading-none tracking-tight">
              {stat.value.replace('+', '')}<sup class="text-[16px] text-gold">{stat.value.includes('+') ? '+' : ''}</sup>
            </div>
            <div class="text-[9.5px] font-medium tracking-[0.12em] text-white/32 uppercase mt-[5px]">{stat.label}</div>
          </div>
        </>
      ))}
    </div>

  </div>

  <!-- Carousel info badge (bottom left) -->
  <div id="car-info" class="absolute bottom-20 left-12 z-[4] text-left pointer-events-none opacity-0 translate-y-2 transition-all duration-600 ease-out md:block hidden">
    <div class="inline-flex items-center gap-1.5 text-[9px] font-bold tracking-[0.18em] uppercase text-gold border border-gold/28 rounded-[4px] px-[10px] py-1 mb-2" style="background: rgba(8,22,40,.65); backdrop-filter: blur(6px);">
      <svg width="6" height="6" viewBox="0 0 6 6"><circle cx="3" cy="3" r="3" fill="#C9A84C"/></svg>
      <span id="car-badge-text">Destaque</span>
    </div>
    <div id="car-title-text" class="text-[clamp(13px,1.6vw,18px)] font-bold text-white leading-tight mb-1 tracking-tight" style="text-shadow: 0 2px 12px rgba(0,0,0,.5);">
      Apartamento Frente Mar — Enseada
    </div>
    <div class="flex items-center gap-1.5 text-[11px] text-white/50">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.68 2 6 4.68 6 8c0 4.5 6 14 6 14s6-9.5 6-14c0-3.32-2.68-6-6-6z"/><circle cx="12" cy="8" r="2"/></svg>
      <span id="car-loc-text">Enseada, Guarujá · R$ 1,85M</span>
    </div>
  </div>

  <!-- Carousel dots -->
  <div id="car-dots" class="absolute z-[4] flex gap-[7px] items-center" style="bottom: 40px; left: 50%; transform: translateX(-50%);">
    {heroSlides.map((_, i) => (
      <button
        class={`car-dot border-none cursor-pointer transition-all duration-350 rounded-[3px] ${i === 0 ? 'w-[22px] h-[6px] bg-gold' : 'w-[6px] h-[6px] bg-white/28'}`}
        data-index={i}
        aria-label={`Slide ${i + 1}`}
      ></button>
    ))}
  </div>

  <!-- Carousel arrows (appear on hover) -->
  <button id="car-prev" class="car-arrow absolute top-1/2 left-5 z-[4] w-[42px] h-[42px] rounded-full border border-white/12 flex items-center justify-center cursor-pointer transition-all duration-200 opacity-0 -translate-y-1/2 hover:bg-white/16 hover:border-white/28" style="background: rgba(255,255,255,.07); backdrop-filter: blur(6px);" aria-label="Anterior">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.8)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button id="car-next" class="car-arrow absolute top-1/2 right-5 z-[4] w-[42px] h-[42px] rounded-full border border-white/12 flex items-center justify-center cursor-pointer transition-all duration-200 opacity-0 -translate-y-1/2 hover:bg-white/16 hover:border-white/28" style="background: rgba(255,255,255,.07); backdrop-filter: blur(6px);" aria-label="Próximo">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.8)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Scroll cue -->
  <div class="absolute z-[4] flex flex-col items-center gap-1.5 text-[9px] font-semibold tracking-[0.18em] text-white/22 uppercase cursor-pointer" style="bottom: 36px; right: 48px;" onclick="document.querySelector('#features').scrollIntoView({behavior:'smooth'})">
    <div class="w-5 h-8 border border-white/18 rounded-[10px] flex justify-center pt-[5px]">
      <div class="w-[3px] h-[6px] bg-gold rounded-sm opacity-60" style="animation: wheelBounce 2s ease-in-out infinite;"></div>
    </div>
    Explorar
  </div>

</section>

<script>
  interface SlideData {
    badge: string;
    title: string;
    location: string;
    gradient: string;
  }

  const slides = Array.from(document.querySelectorAll('.slide')) as HTMLElement[];
  const dots = Array.from(document.querySelectorAll('.car-dot')) as HTMLButtonElement[];
  const carInfo = document.getElementById('car-info');
  const carBadgeText = document.getElementById('car-badge-text');
  const carTitleText = document.getElementById('car-title-text');
  const carLocText = document.getElementById('car-loc-text');
  const heroEl = document.querySelector('.hero') as HTMLElement | null;
  const prevBtn = document.getElementById('car-prev');
  const nextBtn = document.getElementById('car-next');

  const slideData: SlideData[] = [
    { badge: 'Destaque', title: 'Apartamento Frente Mar — Enseada', location: 'Enseada, Guarujá · R$ 1,85M', gradient: '' },
    { badge: 'Exclusivo', title: 'Cobertura Duplex — Riviera', location: 'Riviera de São Lourenço · R$ 3,20M', gradient: '' },
    { badge: 'Novo', title: 'Casa em Condomínio Fechado', location: 'Jardim Acapulco, Guarujá · R$ 2,40M', gradient: '' },
    { badge: 'Destaque', title: 'Cobertura Triplex — Enseada', location: 'Enseada, Guarujá · R$ 4,80M', gradient: '' },
  ];

  let current = 0;
  let autoplay: ReturnType<typeof setInterval>;

  function goSlide(n: number) {
    slides[current]?.classList.remove('opacity-100');
    slides[current]?.classList.add('opacity-0');
    dots[current]?.classList.remove('w-[22px]', 'bg-gold');
    dots[current]?.classList.add('w-[6px]', 'bg-white/28');

    current = (n + slides.length) % slides.length;

    slides[current]?.classList.add('opacity-100');
    slides[current]?.classList.remove('opacity-0');
    dots[current]?.classList.add('w-[22px]', 'bg-gold');
    dots[current]?.classList.remove('w-[6px]', 'bg-white/28');

    // Update info badge
    if (carInfo && slideData[current]) {
      const d = slideData[current];
      if (carBadgeText) carBadgeText.textContent = d.badge;
      if (carTitleText) carTitleText.textContent = d.title;
      if (carLocText) carLocText.textContent = d.location;
      carInfo.classList.remove('opacity-0', 'translate-y-2');
      carInfo.classList.add('opacity-100', 'translate-y-0');
    }
  }

  function startAutoplay() {
    autoplay = setInterval(() => goSlide(current + 1), 5000);
  }

  function resetAutoplay() {
    clearInterval(autoplay);
    startAutoplay();
  }

  // Dot clicks
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { goSlide(i); resetAutoplay(); });
  });

  // Arrow clicks
  prevBtn?.addEventListener('click', () => { goSlide(current - 1); resetAutoplay(); });
  nextBtn?.addEventListener('click', () => { goSlide(current + 1); resetAutoplay(); });

  // Show/hide arrows on hover
  heroEl?.addEventListener('mouseenter', () => {
    prevBtn?.classList.remove('opacity-0');
    prevBtn?.classList.add('opacity-100');
    nextBtn?.classList.remove('opacity-0');
    nextBtn?.classList.add('opacity-100');
  });
  heroEl?.addEventListener('mouseleave', () => {
    prevBtn?.classList.add('opacity-0');
    prevBtn?.classList.remove('opacity-100');
    nextBtn?.classList.add('opacity-0');
    nextBtn?.classList.remove('opacity-100');
  });

  // Initial info badge
  goSlide(0);
  startAutoplay();
</script>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes wheelBounce {
    0%, 100% { transform: translateY(0); opacity: .6; }
    50% { transform: translateY(5px); opacity: .25; }
  }
  @media (max-width: 900px) {
    #car-info { left: 20px; bottom: 90px; }
    .car-arrow { display: none; }
    .scroll-cue { right: 20px; }
    form.search-form { flex-direction: column; gap: 0; padding: 12px; }
  }
</style>
