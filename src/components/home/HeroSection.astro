---
import { siteConfig } from '../../data/siteConfig';

const bgImage = siteConfig.heroSlides[0].image;
---

<section class="hero relative flex flex-col w-full h-screen min-h-[700px] bg-navy overflow-hidden font-sans">

  <!-- Foto de fundo via <img> (evita encoding de & em CSS) -->
  <img
    src={bgImage}
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover object-center opacity-40 mix-blend-overlay"
  />

  <!-- Overlay gradiente -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy/90 via-navy/50 to-navy/95"></div>

  <!-- Conteúdo central -->
  <div class="relative z-10 flex flex-col items-center justify-center flex-1 px-4 text-center mt-8">

    <!-- Overline -->
    <div class="flex items-center gap-4 mb-6">
      <div class="w-8 h-px bg-gold/50"></div>
      <span class="text-gold text-[10px] font-bold tracking-widest uppercase">Guarujá &amp; Litoral Paulista</span>
      <div class="w-8 h-px bg-gold/50"></div>
    </div>

    <!-- Título -->
    <h1 class="text-white font-extrabold text-4xl md:text-5xl lg:text-6xl tracking-tight mb-6 max-w-4xl leading-tight">
      Um imóvel à altura das <br/><span class="text-gold">suas conquistas.</span>
    </h1>

    <!-- Subtítulo -->
    <p class="text-white/70 text-base md:text-lg max-w-2xl mb-12 font-light leading-relaxed">
      Analisamos o momento certo para a sua decisão. Transparência em cada etapa da negociação, com visão de longo prazo para o seu investimento.
    </p>

    <!-- Card de busca rápida -->
    <form
      action="/imoveis"
      method="get"
      class="bg-white p-3 rounded-xl shadow-[0_8px_32px_rgba(11,29,51,0.18)] w-full max-w-5xl mx-auto flex flex-col md:flex-row gap-3 text-left"
    >
      <!-- Localização -->
      <div class="flex-1 px-4 py-2 border-[1.5px] border-navy/10 rounded-lg focus-within:border-gold focus-within:ring-2 focus-within:ring-gold/10 transition-all">
        <label class="block text-[10px] font-bold text-navy/40 uppercase tracking-widest mb-1">Localização</label>
        <input
          type="text"
          name="q"
          placeholder="Ex: Enseada, Pitangueiras..."
          class="w-full text-navy font-medium text-sm outline-none bg-transparent placeholder-navy/30"
        />
      </div>

      <!-- Tipo de imóvel -->
      <div class="flex-1 px-4 py-2 border-[1.5px] border-navy/10 rounded-lg focus-within:border-gold focus-within:ring-2 focus-within:ring-gold/10 transition-all">
        <label class="block text-[10px] font-bold text-navy/40 uppercase tracking-widest mb-1">Tipo de Imóvel</label>
        <select name="tipo" class="w-full text-navy font-medium text-sm outline-none bg-transparent cursor-pointer">
          <option value="">Todos os tipos</option>
          <option value="apartamento">Apartamento</option>
          <option value="casa">Casa</option>
          <option value="cobertura">Cobertura</option>
          <option value="terreno">Terreno</option>
        </select>
      </div>

      <!-- Preço máximo -->
      <div class="flex-1 px-4 py-2 border-[1.5px] border-navy/10 rounded-lg focus-within:border-gold focus-within:ring-2 focus-within:ring-gold/10 transition-all">
        <label class="block text-[10px] font-bold text-navy/40 uppercase tracking-widest mb-1">Valor Máximo</label>
        <select name="preco" class="w-full text-navy font-medium text-sm outline-none bg-transparent cursor-pointer">
          <option value="">Sem limite</option>
          <option value="1000000">Até R$ 1.000.000</option>
          <option value="2500000">Até R$ 2.500.000</option>
          <option value="5000000">Até R$ 5.000.000</option>
          <option value="5000001">Acima de R$ 5.000.000</option>
        </select>
      </div>

      <!-- Botão buscar -->
      <button
        type="submit"
        class="bg-navy hover:bg-navy-mid text-gold font-bold text-sm px-8 py-4 rounded-lg flex items-center justify-center gap-2 transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        Buscar
      </button>
    </form>

  </div>
</section>

<style>
  .hero select option {
    color: #0B1D33;
    background: #ffffff;
  }
</style>
