---
/**
 * Logo Component - MGV Imóveis
 * Based on Pencil design: Logo/Light-H & Logo/White-H
 * Generated from design system
 */

interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}

const { variant = 'light', class: className = '' } = Astro.props;
---

<div class={`inline-flex items-center gap-3 rounded-lg p-4 ${variant === 'light' ? 'bg-white' : 'bg-navy'} ${className}`}>
  <div class="flex flex-col items-start gap-0">
    <span class={`font-heading text-2xl font-semibold ${variant === 'light' ? 'text-navy' : 'text-white'}`}>
      MGV
    </span>
    <span class={`font-accent text-xs font-medium tracking-widest ${variant === 'light' ? 'text-navy' : 'text-white'}`}>
      IMÓVEIS
    </span>
  </div>
  <div class="h-4 w-0.5 bg-gold"></div>
</div>
