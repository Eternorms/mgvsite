---
/**
 * Header Component - MGV Imóveis
 * Based on Pencil design: Header/Main
 * Generated from design system
 */

import Logo from './Logo.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const navItems = [
  { label: 'Imóveis', href: '/imoveis' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];
---

<header class={`flex items-center justify-between bg-white px-8 py-4 ${className}`}>
  <Logo variant="light" />

  <nav class="flex items-center gap-6">
    {navItems.map(({ label, href }) => (
      <a
        href={href}
        class="font-accent text-sm font-medium text-navy transition-colors hover:text-gold"
      >
        {label}
      </a>
    ))}
  </nav>
</header>
