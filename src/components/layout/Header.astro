---
interface Props {
  class?: string;
  alwaysSolid?: boolean;
}

const { class: className = '', alwaysSolid = false } = Astro.props;

const navItems = [
  { label: 'Imóveis', href: '/imoveis' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];

const currentPath = Astro.url.pathname;
---

<!-- ── Utility top bar ── -->
<div id="topbar" class="topbar fixed top-0 left-0 right-0 z-[201] flex items-center justify-between px-12 overflow-hidden" style="height: 36px;">
  <!-- Left: phone -->
  <a href="tel:+5513999999999" class="flex items-center gap-1.5 text-[10.5px] font-medium tracking-[0.04em] no-underline transition-colors topbar-link">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
    </svg>
    (13) 99999-9999
  </a>

  <!-- Right: CRECI + WhatsApp -->
  <div class="hidden md:flex items-center gap-5">
    <span class="text-[10px] tracking-[0.10em] topbar-muted">CRECI/SP 00000-J</span>
    <div class="topbar-divider w-px h-3"></div>
    <a href="https://wa.me/5013999999999" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-[10.5px] font-medium no-underline transition-colors topbar-link">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
    <div class="topbar-divider w-px h-3"></div>
    <a href="/contato" class="text-[10.5px] font-semibold tracking-[0.06em] no-underline transition-colors topbar-link">
      Minha conta
    </a>
  </div>
</div>

<nav
  id="navbar"
  data-scrolled={alwaysSolid ? 'true' : 'false'}
  data-always-solid={alwaysSolid ? 'true' : 'false'}
  class={`fixed left-0 right-0 z-[200] flex items-center justify-between px-12 ${className}`}
  style="top: 36px;"
>
  <!-- Logo -->
  <a href="/" class="flex items-center gap-[10px] no-underline">
    <svg class="logo-svg" width="34" height="37" viewBox="0 0 428 472" fill="none">
      <path class="logo-path" d="M214 216.383L301.654 156.047V216.383H323.191H339.348H357.75V194V171.5V134V102.21V86V78V73.5V69.5H333.5L263.737 116.5L214 151L91.5 69.5L66.75 69.6004V133.792V172.702V191.466V210.23V251.215V271.954V292.758L214.003 386L357.75 293V224H286.127H248.562H232.896H215.005H214.504V254V288L241.55 278H301.654L214.003 326L122.346 268.5V156.047L214 216.383Z"/>
      <path class="logo-path" d="M426 249.5L366 288C366 288 366.5 61.4789 366.5 60H332.5L214 140.5L92 59.9997H58.7385V287L1 250.45V130.944V1H106.5L214 69.5L319.5 1H426V249.5Z"/>
      <path class="logo-path" d="M425.501 327.972L213.75 470.5L1 327.5V262.5L214 400L426 262.5L425.501 327.972Z"/>
    </svg>
    <div>
      <span class="logo-name block text-[13px] font-extrabold tracking-[0.12em] leading-none">MGV IMÓVEIS</span>
      <span class="logo-slogan block text-[7px] font-semibold tracking-[0.22em] mt-[2px]">Valor que Permanece</span>
    </div>
  </a>

  <!-- Nav links -->
  <div class="hidden md:flex items-center gap-8">
    {navItems.map(({ label, href }) => (
      <a
        href={href}
        class={`nav-link text-[13.5px] font-semibold tracking-[0.05em] no-underline ${
          currentPath === href || currentPath.startsWith(href + '/') ? 'active' : ''
        }`}
      >
        {label}
      </a>
    ))}
  </div>

  <!-- CTA button -->
  <button
    id="navbar-cta"
    class="navbar-cta hidden md:flex items-center gap-[7px] text-[12.5px] font-bold tracking-[0.07em] px-[22px] py-[10px] rounded-[8px] border cursor-pointer"
    onclick="window.location.href='/contato'"
  >
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
    Fale conosco
  </button>

  <!-- Mobile hamburger -->
  <button id="hamburger" class="flex md:hidden flex-col gap-[5px] cursor-pointer p-[6px] bg-transparent border-none" aria-label="Menu">
    <span class="hamburger-line w-[22px] h-[2px] rounded-sm block"></span>
    <span class="hamburger-line w-[22px] h-[2px] rounded-sm block"></span>
    <span class="hamburger-line w-[22px] h-[2px] rounded-sm block"></span>
  </button>
</nav>

<div id="mobile-menu" class="fixed inset-0 z-[199] hidden md:hidden" aria-hidden="true">
  <div class="absolute inset-0 bg-navy/90 backdrop-blur-sm"></div>
  <div class="relative mt-[96px] mx-5 rounded-[12px] border border-white/10 bg-white shadow-[0_24px_80px_rgba(0,0,0,0.28)] overflow-hidden">
    <div class="flex flex-col">
      {navItems.map(({ label, href }) => (
        <a
          href={href}
          class={`px-5 py-4 text-[13px] font-bold tracking-[0.08em] no-underline border-b border-navy/10 ${
            currentPath === href || currentPath.startsWith(href + '/') ? 'text-gold' : 'text-navy'
          }`}
        >
          {label}
        </a>
      ))}
      <a href="https://wa.me/5013999999999" target="_blank" rel="noopener" class="mx-5 my-5 flex items-center justify-center gap-2 rounded-[8px] bg-gold px-5 py-3 text-[12px] font-extrabold tracking-[0.08em] text-navy no-underline">
        WhatsApp
      </a>
    </div>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar') as HTMLElement | null;
  const topbar = document.getElementById('topbar') as HTMLElement | null;
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const alwaysSolid = navbar?.dataset.alwaysSolid === 'true';

  function updateNavbar() {
    if (!navbar) return;
    const shouldBeSolid = alwaysSolid || window.scrollY > 20;
    navbar.dataset.scrolled = shouldBeSolid ? 'true' : 'false';

    // Topbar: hide when scrolled (slide up), show when transparent
    if (topbar) {
      if (shouldBeSolid) {
        topbar.style.height = '0px';
        topbar.style.opacity = '0';
        navbar.style.top = '0px';
      } else {
        topbar.style.height = '36px';
        topbar.style.opacity = '1';
        navbar.style.top = '36px';
      }
    }
  }

  updateNavbar();
  window.addEventListener('scroll', updateNavbar, { passive: true });

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    document.documentElement.style.overflow = isOpen ? 'hidden' : '';
  });

  mobileMenu?.addEventListener('click', (event) => {
    if (event.target === mobileMenu || (event.target as HTMLElement).closest('a')) {
      mobileMenu.classList.add('hidden');
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';
    }
  });
</script>

<style>
  /* ══════════════════════════════════════════════
     TOPBAR — barra utilitária fina
  ══════════════════════════════════════════════ */
  .topbar {
    transition: height 0.35s ease, opacity 0.3s ease;
  }

  /* Transparent: topbar branca sobre hero escuro */
  .topbar .topbar-link {
    color: rgba(255, 255, 255, 0.90);
  }
  .topbar .topbar-link:hover {
    color: #ffffff;
  }
  .topbar .topbar-muted {
    color: rgba(255, 255, 255, 0.75);
    font-size: 10px;
    letter-spacing: 0.10em;
  }
  .topbar .topbar-divider {
    background: rgba(255, 255, 255, 0.25);
  }

  /* ─── Transição suave: fundo, sombra e altura ─── */
  nav {
    transition: background 0.4s ease, box-shadow 0.4s ease, height 0.4s ease, top 0.35s ease, border-color 0.4s ease;
  }

  /* ══════════════════════════════════════════════
     ESTADO TRANSPARENT — sobre o hero (logo branco)
  ══════════════════════════════════════════════ */
  nav {
    background: transparent;
    box-shadow: none;
    height: 92px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
  }

  /* Ícone SVG: branco + maior no estado transparente */
  nav .logo-svg {
    width: 54px;
    height: 59px;
    transition: width 0.4s ease, height 0.4s ease;
  }
  nav .logo-svg .logo-path {
    fill: #ffffff;
    transition: fill 0.4s ease;
  }

  /* Texto "MGV IMÓVEIS": branco + maior no estado transparente */
  nav .logo-name {
    color: #ffffff;
    font-size: 17px;
    transition: color 0.3s ease, font-size 0.4s ease;
  }

  /* Slogan "Valor que Permanece": branco + maior no estado transparente */
  nav .logo-slogan {
    color: #ffffff;
    opacity: 0.70;
    font-size: 9.5px;
    transition: color 0.4s ease, opacity 0.4s ease, font-size 0.4s ease;
  }

  nav .nav-link {
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.2s ease;
  }
  nav .nav-link:hover { color: rgba(255, 255, 255, 0.95); }
  nav .nav-link.active { color: #C9A84C !important; }

  nav .navbar-cta {
    background: transparent;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.25);
    transition: background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  nav .navbar-cta:hover {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.50);
  }

  nav .hamburger-line {
    background: #ffffff;
    transition: background 0.3s ease;
  }

  /* ══════════════════════════════════════════════
     ESTADO SCROLLED — sólido (logo colorido)
  ══════════════════════════════════════════════ */
  nav[data-scrolled="true"] {
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(11, 29, 51, 0.08), 0 4px 24px rgba(11, 29, 51, 0.06);
    border-bottom: none;
    height: 64px;
  }

  /* Ícone SVG: gold + tamanho normal */
  nav[data-scrolled="true"] .logo-svg {
    width: 42px;
    height: 46px;
  }
  nav[data-scrolled="true"] .logo-svg .logo-path {
    fill: #C9A84C;
  }

  /* Texto "MGV IMÓVEIS": navy + tamanho normal */
  nav[data-scrolled="true"] .logo-name {
    color: #0B1D33;
    font-size: 15px;
  }

  /* Slogan: gold + tamanho normal */
  nav[data-scrolled="true"] .logo-slogan {
    color: #C9A84C;
    opacity: 0.80;
    font-size: 8px;
  }

  nav[data-scrolled="true"] .nav-link {
    color: rgba(11, 29, 51, 0.50);
  }
  nav[data-scrolled="true"] .nav-link:hover { color: #0B1D33; }
  nav[data-scrolled="true"] .nav-link.active { color: #C9A84C !important; }

  nav[data-scrolled="true"] .navbar-cta {
    background: #C9A84C;
    color: #0B1D33;
    border-color: #C9A84C;
  }
  nav[data-scrolled="true"] .navbar-cta:hover {
    background: #A8882E;
    box-shadow: 0 6px 24px rgba(201, 168, 76, 0.32);
  }

  nav[data-scrolled="true"] .hamburger-line { background: #0B1D33; }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    nav { padding-left: 20px; padding-right: 20px; height: 72px; }
    nav[data-scrolled="true"] { height: 60px; }
    .topbar { padding-left: 20px; padding-right: 20px; }
  }
</style>
