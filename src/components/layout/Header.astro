---
interface Props {
  variant?: 'transparent' | 'solid';
}

const { variant = 'solid' } = Astro.props;

const navLinks = [
  { href: '/imoveis', label: 'Imóveis' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];

const isTransparent = variant === 'transparent';
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    isTransparent ? 'bg-transparent' : 'bg-white shadow-sm',
  ]}
  data-header
>
  <div class="container-custom">
    <nav class="flex items-center justify-between h-20 lg:h-24">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src={isTransparent ? '/images/logo-white.svg' : '/images/logo-dark.svg'}
          alt="MGV Imóveis"
          class="h-10 lg:h-12 transition-opacity duration-300"
          data-logo
          data-logo-white="/images/logo-white.svg"
          data-logo-dark="/images/logo-dark.svg"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'font-accent text-sm font-medium uppercase tracking-wider transition-colors duration-200',
              isTransparent
                ? 'text-white hover:text-gold'
                : 'text-navy hover:text-gold',
            ]}
            data-nav-link
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Phone & CTA -->
      <div class="hidden lg:flex items-center gap-6">
        <a
          href="tel:+5541999999999"
          class:list={[
            'flex items-center gap-2 font-accent text-sm font-medium transition-colors duration-200',
            isTransparent
              ? 'text-white hover:text-gold'
              : 'text-navy hover:text-gold',
          ]}
          data-nav-link
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (41) 99999-9999
        </a>
        <a
          href="/contato"
          class="btn-primary text-xs px-5 py-2.5"
        >
          Agende uma visita
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        class="lg:hidden flex items-center gap-4"
        aria-label="Menu"
        data-menu-toggle
      >
        <a
          href="tel:+5541999999999"
          class:list={[
            'p-2',
            isTransparent ? 'text-white' : 'text-navy',
          ]}
          data-nav-link
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
        <div
          class:list={[
            'p-2',
            isTransparent ? 'text-white' : 'text-navy',
          ]}
          data-nav-link
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-menu-icon>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </div>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    class="lg:hidden fixed inset-0 bg-navy z-50 transform translate-x-full transition-transform duration-300"
    data-mobile-menu
  >
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between h-20 px-4">
        <a href="/">
          <img src="/images/logo-white.svg" alt="MGV Imóveis" class="h-10" />
        </a>
        <button class="p-2 text-white" data-menu-close aria-label="Fechar menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="flex-1 flex flex-col justify-center items-center gap-8 px-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-heading text-2xl text-white hover:text-gold transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a href="/contato" class="btn-primary mt-8">
          Agende uma visita
        </a>
      </nav>
      <div class="p-8 text-center">
        <a href="tel:+5541999999999" class="text-white font-accent">
          (41) 99999-9999
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.querySelector('[data-header]') as HTMLElement;
  const logo = document.querySelector('[data-logo]') as HTMLImageElement;
  const navLinks = document.querySelectorAll('[data-nav-link]');
  const isTransparent = header?.classList.contains('bg-transparent');

  if (isTransparent && header && logo) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-white', 'shadow-sm');
        logo.src = logo.dataset.logoDark || logo.src;
        navLinks.forEach((link) => {
          link.classList.remove('text-white');
          link.classList.add('text-navy');
        });
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-white', 'shadow-sm');
        logo.src = logo.dataset.logoWhite || logo.src;
        navLinks.forEach((link) => {
          link.classList.add('text-white');
          link.classList.remove('text-navy');
        });
      }
    });
  }

  // Mobile menu toggle
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const menuClose = document.querySelector('[data-menu-close]');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  });

  menuClose?.addEventListener('click', () => {
    mobileMenu?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  });
</script>
