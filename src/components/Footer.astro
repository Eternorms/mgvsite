---
/**
 * Footer Component - MGV Imóveis
 * Based on Pencil design: Footer/Main
 * Generated from design system
 */

import Logo from './Logo.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const footerLinks = [
  { label: 'Política de Privacidade', href: '/privacidade' },
  { label: 'Termos de Uso', href: '/termos' },
];
---

<footer class={`flex flex-col gap-6 bg-navy px-8 py-8 ${className}`}>
  <Logo variant="dark" />

  <p class="max-w-full font-body text-sm text-white/70">
    Há mais de 15 anos realizando sonhos no litoral do Paraná.
  </p>

  <div class="flex w-full gap-6">
    {footerLinks.map(({ label, href }) => (
      <a
        href={href}
        class="font-body text-sm text-white/70 transition-colors hover:text-white"
      >
        {label}
      </a>
    ))}
  </div>

  <p class="max-w-full font-body text-xs text-white/50">
    © 2026 MGV Imóveis. Todos os direitos reservados.
  </p>
</footer>
