---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import PropertyCard from '../../components/ui/PropertyCard.astro';
import { properties, getPropertyBySlug } from '../../data/properties';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return properties.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const property = getPropertyBySlug(slug);

if (!property) {
  return Astro.redirect('/imoveis');
}

const { title, location, city, price, type, badge, badgeType, beds, baths, area, gradient, description } = property;

const badgeClasses: Record<string, string> = {
  gold: 'bg-gold text-navy',
  navy: 'bg-navy/85 text-white border border-gold/30',
  excl: 'bg-gold/14 text-gold border border-gold/35',
};

// Related: other properties excluding current
const related = properties.filter((p) => p.slug !== slug).slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <Header alwaysSolid />

  <!-- Hero image -->
  <div class="relative pt-[72px]" style="height: 520px;">
    <div class="absolute inset-0" style={`background: ${gradient};`}></div>
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(8,22,40,.4) 0%, rgba(8,22,40,.7) 100%);"></div>

    <!-- Breadcrumb + badge overlay -->
    <div class="absolute bottom-10 left-12 z-10">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-[11px] text-white/45 mb-4">
        <a href="/" class="text-white/45 no-underline hover:text-white/70 transition-colors">Home</a>
        <span>/</span>
        <a href="/imoveis" class="text-white/45 no-underline hover:text-white/70 transition-colors">Imóveis</a>
        <span>/</span>
        <span class="text-white/70">{title}</span>
      </div>

      {badge && (
        <span class={`inline-block text-[9px] font-bold tracking-[0.14em] uppercase px-[10px] py-1 rounded-[4px] mb-3 ${badgeClasses[badgeType]}`}>
          {badge}
        </span>
      )}
      <h1 class="text-[clamp(24px,3.5vw,40px)] font-extrabold text-white tracking-tight leading-tight mb-2" style="text-shadow: 0 2px 20px rgba(0,0,0,.4);">
        {title}
      </h1>
      <div class="flex items-center gap-1.5 text-[13px] text-white/60">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.68 2 6 4.68 6 8c0 4.5 6 14 6 14s6-9.5 6-14c0-3.32-2.68-6-6-6z"/><circle cx="12" cy="8" r="2"/></svg>
        {location}, {city}
      </div>
    </div>

    <!-- Price badge top right -->
    <div class="absolute top-[100px] right-12 z-10 bg-navy/80 backdrop-blur-md rounded-[10px] px-5 py-3 text-right">
      <div class="text-[10px] font-bold tracking-[0.15em] uppercase text-white/40 mb-1">Preço</div>
      <div class="text-[26px] font-extrabold text-gold tracking-tight leading-none">{price}</div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-[1200px] mx-auto px-12 py-14">
    <div class="grid gap-10" style="grid-template-columns: 1fr 340px;">

      <!-- Left: details -->
      <div>
        <!-- Specs bar -->
        <div class="flex gap-8 p-6 bg-white rounded-[12px] border border-navy/7 shadow-[0_4px_20px_rgba(11,29,51,0.08)] mb-8">
          {beds > 0 && (
            <div class="flex flex-col items-center gap-1">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16M2 8h18a2 2 0 012 2v10M2 16h20"/><path d="M6 8V4"/></svg>
              <span class="text-[20px] font-extrabold text-navy leading-none">{beds}</span>
              <span class="text-[10px] font-medium text-navy/45 uppercase tracking-wider">Quartos</span>
            </div>
          )}
          {baths > 0 && (
            <div class="flex flex-col items-center gap-1">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 A3 3 0 0 1 15 6 L15 11 L3 11 L3 13 A9 9 0 0 0 21 13 L21 11 L15 11"/></svg>
              <span class="text-[20px] font-extrabold text-navy leading-none">{baths}</span>
              <span class="text-[10px] font-medium text-navy/45 uppercase tracking-wider">Banheiros</span>
            </div>
          )}
          <div class="flex flex-col items-center gap-1">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            <span class="text-[20px] font-extrabold text-navy leading-none">{area}</span>
            <span class="text-[10px] font-medium text-navy/45 uppercase tracking-wider">m² Área</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="text-[14px] font-extrabold text-navy leading-none">{type}</span>
            <span class="text-[10px] font-medium text-navy/45 uppercase tracking-wider">Tipo</span>
          </div>
        </div>

        <!-- Description -->
        <h2 class="text-[18px] font-bold text-navy mb-4">Sobre o imóvel</h2>
        <p class="text-[14px] text-navy/65 leading-[1.8] mb-8">{description}</p>

        <!-- Gallery placeholder -->
        <h2 class="text-[18px] font-bold text-navy mb-4">Galeria de fotos</h2>
        <div class="grid grid-cols-3 gap-3 mb-8">
          {[0,1,2,3,4,5].map((i) => (
            <div
              class={`rounded-[10px] overflow-hidden ${i === 0 ? 'col-span-2 row-span-2' : ''}`}
              style={`height: ${i === 0 ? '280px' : '130px'}; background: ${gradient}; opacity: ${0.7 + i * 0.05};`}
            ></div>
          ))}
        </div>

        <!-- Features list -->
        <h2 class="text-[18px] font-bold text-navy mb-4">Características</h2>
        <div class="grid grid-cols-2 gap-3">
          {['Varanda gourmet', 'Piscina no condomínio', 'Academia', 'Salão de festas', 'Portaria 24h', 'Estacionamento coberto', 'Elevador', 'Vista para o mar'].map((feat) => (
            <div class="flex items-center gap-2 text-[13px] text-navy/65">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {feat}
            </div>
          ))}
        </div>
      </div>

      <!-- Right: contact sidebar -->
      <div class="sticky top-[90px] self-start">

        <!-- Agent card -->
        <div class="bg-white rounded-[14px] border border-navy/8 shadow-[0_4px_20px_rgba(11,29,51,0.08)] p-6 mb-5">
          <div class="flex items-center gap-4 mb-5">
            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-navy to-navy-mid flex items-center justify-center text-[24px] font-bold text-gold shrink-0">M</div>
            <div>
              <div class="text-[14px] font-bold text-navy">Marcos Vinícius</div>
              <div class="text-[11px] text-navy/45 mt-0.5">Consultor Sênior · MGV Imóveis</div>
              <div class="flex items-center gap-1 mt-1">
                {[1,2,3,4,5].map(() => (
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="#C9A84C" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
                <span class="text-[10px] text-navy/40 ml-1">5.0</span>
              </div>
            </div>
          </div>

          <div class="flex gap-3 mb-5">
            <div class="flex-1 text-center py-2 bg-navy/4 rounded-[8px]">
              <div class="text-[16px] font-extrabold text-navy">47+</div>
              <div class="text-[9px] text-navy/40 uppercase tracking-wider">Imóveis</div>
            </div>
            <div class="flex-1 text-center py-2 bg-navy/4 rounded-[8px]">
              <div class="text-[16px] font-extrabold text-navy">12</div>
              <div class="text-[9px] text-navy/40 uppercase tracking-wider">Anos</div>
            </div>
          </div>

          <a
            href={siteConfig.contact.whatsappHref + `?text=Olá! Tenho interesse no imóvel: ${encodeURIComponent(title)}`}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 w-full py-3 bg-[#25D366] text-white font-bold text-[12px] tracking-[0.05em] rounded-[9px] no-underline transition-colors hover:bg-[#20b858] mb-2"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>

          <a
            href={siteConfig.contact.phoneHref}
            class="flex items-center justify-center gap-2 w-full py-3 bg-transparent text-navy font-bold text-[12px] tracking-[0.05em] rounded-[9px] no-underline border border-navy/15 transition-colors hover:border-navy"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {siteConfig.contact.phone}
          </a>
        </div>

        <!-- Quick form -->
        <div class="bg-white rounded-[14px] border border-navy/8 shadow-[0_4px_20px_rgba(11,29,51,0.08)] p-6">
          <div class="text-[13px] font-bold text-navy mb-4">Agende uma visita</div>
          <form class="flex flex-col gap-3">
            <input
              type="text"
              placeholder="Seu nome"
              class="text-[12.5px] text-navy bg-gray-50 border border-navy/10 rounded-[8px] px-4 py-[10px] outline-none transition-colors focus:border-gold placeholder-navy/30"
            />
            <input
              type="tel"
              placeholder="Seu telefone / WhatsApp"
              class="text-[12.5px] text-navy bg-gray-50 border border-navy/10 rounded-[8px] px-4 py-[10px] outline-none transition-colors focus:border-gold placeholder-navy/30"
            />
            <textarea
              placeholder="Mensagem (opcional)"
              rows={3}
              class="text-[12.5px] text-navy bg-gray-50 border border-navy/10 rounded-[8px] px-4 py-[10px] outline-none transition-colors focus:border-gold placeholder-navy/30 resize-none"
            ></textarea>
            <button
              type="submit"
              class="w-full py-[11px] bg-gold text-navy font-bold text-[12px] tracking-[0.07em] rounded-[9px] border-none cursor-pointer transition-colors hover:bg-gold-dark"
              style="color: #0B1D33;"
            >
              Enviar mensagem
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>

  <!-- Related properties -->
  {related.length > 0 && (
    <div class="py-14 px-12" style="background: #FAFAFA;">
      <div class="max-w-[1200px] mx-auto">
        <h2 class="text-[22px] font-extrabold text-navy mb-6">Outros imóveis</h2>
        <div class="grid grid-cols-3 gap-6">
          {related.map((p) => (
            <PropertyCard property={p} />
          ))}
        </div>
      </div>
    </div>
  )}

  <Footer />
</BaseLayout>

<style>
  @media (max-width: 900px) {
    .grid[style*="grid-template-columns: 1fr 340px"] {
      grid-template-columns: 1fr !important;
    }
    .sticky { position: static !important; }
    .px-12 { padding-left: 20px !important; padding-right: 20px !important; }
  }
</style>
