---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout
  title="Contato"
  description="Entre em contato com a MGV Imóveis. Atendimento personalizado por telefone, WhatsApp ou formulário."
>
  <Header alwaysSolid />

  <!-- Hero -->
  <div class="pt-[120px] pb-[56px] px-12" style="background: #0B1D33;">
    <div class="max-w-[800px] mx-auto text-center">
      <div class="flex items-center justify-center gap-3 text-[10px] font-bold tracking-[0.28em] text-gold uppercase mb-6 before:content-[''] before:w-8 before:h-px before:bg-gold before:opacity-50 after:content-[''] after:w-8 after:h-px after:bg-gold after:opacity-50">
        Fale com a gente
      </div>
      <h1 class="text-[clamp(28px,4.5vw,48px)] font-extrabold text-white tracking-tight mb-4" style="font-family: 'Playfair Display', serif;">
        Como podemos <em style="color: #C9A84C; font-style: italic;">ajudar?</em>
      </h1>
      <p class="text-[14px] text-white/50 leading-relaxed max-w-md mx-auto">
        Nossa equipe responde em até 2 horas em horário comercial. Escolha o canal de sua preferência.
      </p>
    </div>
  </div>

  <!-- Contact content -->
  <div class="py-[64px] px-12 bg-white">
    <div class="max-w-[1000px] mx-auto grid gap-10" style="grid-template-columns: 1fr 380px;">

      <!-- Left: form -->
      <div>
        <h2 class="text-[20px] font-bold text-navy mb-6">Envie uma mensagem</h2>
        <form class="flex flex-col gap-4" id="contact-form">
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[10px] font-bold tracking-[0.14em] uppercase text-navy/45">Seu nome *</label>
              <input
                type="text"
                name="nome"
                required
                placeholder="Ex: João Silva"
                class="text-[13px] text-navy bg-gray-50 border border-navy/10 rounded-[9px] px-4 py-[11px] outline-none transition-colors focus:border-gold placeholder-navy/25"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[10px] font-bold tracking-[0.14em] uppercase text-navy/45">Telefone / WhatsApp *</label>
              <input
                type="tel"
                name="telefone"
                required
                placeholder="(13) 99999-9999"
                class="text-[13px] text-navy bg-gray-50 border border-navy/10 rounded-[9px] px-4 py-[11px] outline-none transition-colors focus:border-gold placeholder-navy/25"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold tracking-[0.14em] uppercase text-navy/45">E-mail</label>
            <input
              type="email"
              name="email"
              placeholder="seu@email.com.br"
              class="text-[13px] text-navy bg-gray-50 border border-navy/10 rounded-[9px] px-4 py-[11px] outline-none transition-colors focus:border-gold placeholder-navy/25"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold tracking-[0.14em] uppercase text-navy/45">Assunto</label>
            <div class="relative">
              <select
                name="assunto"
                class="appearance-none w-full text-[13px] text-navy bg-gray-50 border border-navy/10 rounded-[9px] px-4 py-[11px] pr-10 outline-none transition-colors focus:border-gold cursor-pointer"
              >
                <option value="">Selecione o assunto</option>
                <option>Quero comprar um imóvel</option>
                <option>Quero alugar um imóvel</option>
                <option>Quero vender meu imóvel</option>
                <option>Quero colocar para alugar</option>
                <option>Dúvida geral</option>
              </select>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0B1D33" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold tracking-[0.14em] uppercase text-navy/45">Mensagem</label>
            <textarea
              name="mensagem"
              rows={5}
              placeholder="Descreva o que você está procurando, faixa de preço, região preferida..."
              class="text-[13px] text-navy bg-gray-50 border border-navy/10 rounded-[9px] px-4 py-[11px] outline-none transition-colors focus:border-gold placeholder-navy/25 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="flex items-center justify-center gap-2 w-full py-[13px] bg-gold text-navy font-bold text-[12px] tracking-[0.08em] rounded-[10px] border-none cursor-pointer transition-all hover:bg-gold-dark"
            style="color: #0B1D33;"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Enviar mensagem
          </button>

          <p class="text-[11px] text-navy/35 text-center">Respondemos em até 2 horas em horário comercial (seg–sex 9h–18h)</p>
        </form>

        <!-- Success message (hidden) -->
        <div id="success-msg" class="hidden mt-6 p-5 bg-green-50 border border-green-200 rounded-[12px] text-center">
          <div class="text-[24px] mb-2">✅</div>
          <div class="text-[14px] font-bold text-green-800 mb-1">Mensagem enviada!</div>
          <div class="text-[12px] text-green-700">Entraremos em contato em breve. Obrigado!</div>
        </div>
      </div>

      <!-- Right: contact info -->
      <div class="flex flex-col gap-5">

        <!-- WhatsApp card -->
        <a
          href={siteConfig.contact.whatsappHref}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 p-5 rounded-[14px] border border-[#25D366]/25 bg-[#25D366]/5 no-underline transition-colors group hover:bg-[#25D366]/10"
        >
          <div class="w-12 h-12 rounded-[12px] bg-[#25D366] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <div class="text-[13px] font-bold text-navy mb-0.5">WhatsApp</div>
            <div class="text-[12px] text-navy/55">{siteConfig.contact.phone}</div>
          </div>
          <svg class="ml-auto text-navy/20 group-hover:text-navy/40 transition-colors" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Phone card -->
        <a
          href={siteConfig.contact.phoneHref}
          class="flex items-center gap-4 p-5 rounded-[14px] border border-navy/10 bg-navy/3 no-underline transition-colors group hover:bg-navy/6"
        >
          <div class="w-12 h-12 rounded-[12px] bg-navy flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <div class="text-[13px] font-bold text-navy mb-0.5">Telefone</div>
            <div class="text-[12px] text-navy/55">{siteConfig.contact.phone}</div>
          </div>
        </a>

        <!-- Email card -->
        <a
          href={`mailto:${siteConfig.contact.email}`}
          class="flex items-center gap-4 p-5 rounded-[14px] border border-navy/10 bg-navy/3 no-underline transition-colors group hover:bg-navy/6"
        >
          <div class="w-12 h-12 rounded-[12px] bg-navy flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="text-[13px] font-bold text-navy mb-0.5">E-mail</div>
            <div class="text-[12px] text-navy/55">{siteConfig.contact.email}</div>
          </div>
        </a>

        <!-- Address -->
        <div class="p-5 rounded-[14px] border border-navy/10 bg-navy/3">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-[10px] bg-navy/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0B1D33" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"><path d="M12 2C8.68 2 6 4.68 6 8c0 4.5 6 14 6 14s6-9.5 6-14c0-3.32-2.68-6-6-6z"/><circle cx="12" cy="8" r="2"/></svg>
            </div>
            <div>
              <div class="text-[12px] font-bold text-navy mb-1">Endereço</div>
              <div class="text-[12px] text-navy/55 leading-relaxed">
                {siteConfig.contact.address}<br/>
                {siteConfig.contact.city} — {siteConfig.contact.cep}
              </div>
              <div class="text-[11px] text-gold font-semibold mt-2">{siteConfig.contact.creci}</div>
            </div>
          </div>
        </div>

        <!-- Hours -->
        <div class="p-5 rounded-[14px] border border-gold/20 bg-gold/5">
          <div class="text-[12px] font-bold text-navy mb-3">Horário de atendimento</div>
          <div class="flex flex-col gap-2">
            <div class="flex justify-between text-[12px]">
              <span class="text-navy/55">Segunda a Sexta</span>
              <span class="font-semibold text-navy">9h – 18h</span>
            </div>
            <div class="flex justify-between text-[12px]">
              <span class="text-navy/55">Sábado</span>
              <span class="font-semibold text-navy">9h – 13h</span>
            </div>
            <div class="flex justify-between text-[12px]">
              <span class="text-navy/55">Domingo</span>
              <span class="font-semibold text-navy/40">Fechado</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('success-msg');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    successMsg?.classList.remove('hidden');
  });
</script>

<style>
  @media (max-width: 900px) {
    .grid[style*="grid-template-columns: 1fr 380px"] {
      grid-template-columns: 1fr !important;
    }
    .px-12 { padding-left: 20px !important; padding-right: 20px !important; }
    .grid-cols-2 { grid-template-columns: 1fr !important; }
  }
</style>
