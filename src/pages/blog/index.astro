---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { blogPosts as posts } from '../../data/blogPosts';

const categories = ['Todos', 'Mercado', 'Guias', 'Investimento'];
---

<BaseLayout
  title="Blog — Conteúdo sobre o mercado imobiliário"
  description="Artigos, guias e análises sobre o mercado imobiliário do litoral paulista. Guarujá, Riviera de São Lourenço e Santos."
>
  <Header alwaysSolid />

  <!-- Header -->
  <div class="pt-[120px] pb-[56px] px-12" style="background: #0B1D33;">
    <div class="max-w-[900px] mx-auto text-center">
      <div class="flex items-center justify-center gap-3 text-[10px] font-bold tracking-[0.28em] text-gold uppercase mb-6 before:content-[''] before:w-8 before:h-px before:bg-gold before:opacity-50 after:content-[''] after:w-8 after:h-px after:bg-gold after:opacity-50">
        Blog & Conteúdo
      </div>
      <h1 class="text-[clamp(28px,4vw,44px)] font-extrabold text-white tracking-tight mb-4" style="font-family: 'Playfair Display', serif;">
        Insights do mercado imobiliário
      </h1>
      <p class="text-[14px] text-white/50 max-w-md mx-auto leading-relaxed">
        Artigos, guias e análises para ajudá-lo a tomar as melhores decisões no mercado imobiliário do litoral paulista.
      </p>
    </div>
  </div>

  <!-- Category filter tabs -->
  <div class="bg-white border-b border-navy/10 px-12 py-4">
    <div class="max-w-[1000px] mx-auto flex items-center gap-2">
      {categories.map((cat, i) => (
        <button
          class={`blog-cat text-[11.5px] font-semibold px-4 py-[8px] rounded-full border transition-all duration-200 cursor-pointer ${i === 0 ? 'bg-navy text-white border-navy' : 'bg-transparent text-navy/50 border-navy/10 hover:border-navy/50 hover:text-navy'}`}
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- Posts grid -->
  <div class="py-[56px] px-12" style="background: #FAFAFA;">
    <div class="max-w-[1000px] mx-auto">
      <div id="posts-grid" class="grid grid-cols-3 gap-6">
        {posts.map((post) => (
          <article
            class="bg-white rounded-[14px] overflow-hidden border border-navy/10 shadow-[0_4px_20px_rgba(11,29,51,0.08)] cursor-pointer transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
            data-category={post.category}
          >
            <div class="h-[160px] relative overflow-hidden">
              <img src={post.image} alt="" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
              <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 40%, rgba(8,22,40,.6) 100%);"></div>
              <div class="absolute top-3 left-3 text-[9px] font-bold tracking-[0.12em] uppercase px-[10px] py-1 rounded-[4px] bg-gold text-navy">
                {post.category}
              </div>
            </div>

            <div class="p-5">
              <div class="flex items-center gap-3 text-[10px] text-navy/50 mb-3">
                <span>{post.date}</span>
                <span>·</span>
                <span>{post.readTime} leitura</span>
              </div>
              <h2 class="text-[14px] font-bold text-navy leading-snug mb-3 line-clamp-2">{post.title}</h2>
              <p class="text-[12px] text-navy/50 leading-[1.65] line-clamp-3 mb-4">{post.excerpt}</p>
              <a
                href={`/blog/${post.slug}`}
                class="flex items-center gap-1.5 text-[11px] font-bold text-gold no-underline transition-colors hover:text-gold-dark"
              >
                Ler artigo
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Newsletter CTA -->
  <div class="py-[64px] px-12 bg-white text-center">
    <div class="max-w-[520px] mx-auto">
      <h2 class="text-[22px] font-extrabold text-navy tracking-tight mb-3">Receba novidades em primeira mão</h2>
      <p class="text-[13px] text-navy/50 mb-6">Novos imóveis, análises de mercado e dicas exclusivas direto no seu e-mail.</p>
      <form class="flex gap-2 max-w-[400px] mx-auto">
        <input
          type="email"
          placeholder="seu@email.com.br"
          class="flex-1 text-[13px] text-navy bg-gray-50 border border-navy/10 rounded-[9px] px-4 py-[11px] outline-none transition-colors focus:border-gold placeholder-navy/50"
        />
        <button
          type="submit"
          class="px-6 py-[11px] bg-gold text-navy font-bold text-[12px] tracking-[0.06em] rounded-[9px] border-none cursor-pointer whitespace-nowrap transition-colors hover:bg-gold-dark"
          style="color: #0B1D33;"
        >
          Assinar
        </button>
      </form>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script>
  const catBtns = document.querySelectorAll('.blog-cat');
  const articles = document.querySelectorAll('#posts-grid article');

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      catBtns.forEach((b) => {
        b.classList.remove('bg-navy', 'text-white', 'border-navy');
        b.classList.add('bg-transparent', 'text-navy/50', 'border-navy/10');
      });
      btn.classList.add('bg-navy', 'text-white', 'border-navy');
      btn.classList.remove('bg-transparent', 'text-navy/50', 'border-navy/10');

      const selected = btn.getAttribute('data-category');
      articles.forEach((article) => {
        const el = article as HTMLElement;
        el.style.display = (selected === 'Todos' || el.getAttribute('data-category') === selected) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  @media (max-width: 900px) {
    #posts-grid { grid-template-columns: 1fr !important; gap: 16px; }
    .px-12 { padding-left: 20px !important; padding-right: 20px !important; }
  }
  @media (min-width: 901px) and (max-width: 1100px) {
    #posts-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
