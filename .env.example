# Automação Pencil → Astro → GitHub
# Copie este arquivo para .env e preencha com suas configurações

# GitHub Token (opcional - necessário apenas se autoPush estiver habilitado)
# Crie em: https://github.com/settings/tokens
# Permissões necessárias: repo (acesso completo)
GITHUB_TOKEN=

# Caminho do arquivo Pencil (opcional - sobrescreve automation.config.json)
PENCIL_FILE_PATH=.pencil/pencil-new.pen

# Habilitar/Desabilitar funcionalidades
AUTO_PUSH_ENABLED=false
AUTO_COMMIT_ENABLED=true

# Branch padrão para commits
BRANCH_NAME=main

# Modo de desenvolvimento (verbose logs)
DEBUG=false
